            ' / Corr=' + correlationMode,

          noiseSd: noise,
          venueWeight: venueWeight,
          correlationMode: correlationMode
        });
      });
    });
  });

  return models;
}


/* =========================================================
 * Calibration
 * ========================================================= */

function btEmptyBins_() {
  return Array.from({length: 10}, function() {
    return {
      count: 0,
      predictedSum: 0,
      actualSum: 0
    };
  });
}


function btAddCalibration_(bins, probability, actual) {
  const p = btClamp_(Number(probability), 0, 1);
  const index = Math.min(Math.floor(p * 10), 9);

  bins[index].count++;
  bins[index].predictedSum += p;
  bins[index].actualSum += actual;
}


function btCalibrationRows_(testId, target, bins, createdAt) {
  return bins.map(function(bin, i) {
    const lower = i / 10;
    const upper = (i + 1) / 10;

    const averagePredicted =
      bin.count ? bin.predictedSum / bin.count : '';

    const actualRate =
      bin.count ? bin.actualSum / bin.count : '';

    const difference =
      bin.count ? actualRate - averagePredicted : '';

    return [
      testId,
      target,
      lower,
      upper,
      bin.count,
      averagePredicted,
      actualRate,
      difference,
      createdAt
    ];
  });
}


/* =========================================================
 * 乱数・行列
 * ========================================================= */

/**
 * Race_IDだけをseedにするため、全モデルで同一レースには
 * 同じ標準正規乱数系列を使用します。
 * モデル間比較のMonte Carloノイズを抑える狙いです。
 */
function btCreateRng_(seed) {
  let state = (seed >>> 0) || 123456789;

  return function() {
    state = (1664525 * state + 1013904223) >>> 0;
    return (state + 0.5) / 4294967296;
  };
}


function btSixNormals_(rng) {
  const result = [];

  while (result.length < 6) {
    const u1 = Math.max(rng(), 1e-12);
    const u2 = rng();

    const radius = Math.sqrt(-2 * Math.log(u1));
    const angle = 2 * Math.PI * u2;

    result.push(radius * Math.cos(angle));
    if (result.length < 6) {
      result.push(radius * Math.sin(angle));
    }
  }

  return result;
}


function btHashString_(text) {
  let hash = 2166136261;

  for (let i = 0; i < text.length; i++) {
    hash ^= text.charCodeAt(i);
    hash = Math.imul(hash, 16777619);
  }

  return hash >>> 0;
}


function btCholesky_(matrix) {
  const n = matrix.length;
  const lower = Array.from({length: n}, function() {
    return Array(n).fill(0);
  });

  for (let i = 0; i < n; i++) {
    for (let j = 0; j <= i; j++) {
      let sum = 0;

      for (let k = 0; k < j; k++) {
        sum += lower[i][k] * lower[j][k];
      }

      if (i === j) {
        const value = matrix[i][i] - sum;
        lower[i][j] = Math.sqrt(Math.max(value, 1e-12));
      } else {
        lower[i][j] =
          (matrix[i][j] - sum) / lower[j][j];
      }
    }
  }

  return lower;
}


function btIdentityMatrix_(n) {
  return Array.from({length: n}, function(_, i) {
    return Array.from({length: n}, function(__, j) {
      return i === j ? 1 : 0;
    });
  });
}


function btMultiplyLower_(lower, vector) {
  const result = Array(lower.length).fill(0);

  for (let i = 0; i < lower.length; i++) {
    let sum = 0;

    for (let j = 0; j <= i; j++) {
      sum += lower[i][j] * vector[j];
    }

    result[i] = sum;
  }

  return result;
}


