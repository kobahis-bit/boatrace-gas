function btFormatOutputSheets_(ss) {
  const parameter = ss.getSheetByName(BT_ENGINE.PARAMETER_SHEET);
  const summary = ss.getSheetByName(BT_ENGINE.SUMMARY_SHEET);
  const calibration = ss.getSheetByName(BT_ENGINE.CALIBRATION_SHEET);

  [parameter, summary, calibration].forEach(function(sheet) {
    if (!sheet) return;

    const lastColumn = sheet.getLastColumn();

    sheet.getRange(1, 1, 1, lastColumn)
      .setFontWeight('bold')
      .setBackground('#d9eaf7')
      .setWrap(true);

    sheet.setFrozenRows(1);
  });

  parameter.getRange('K2:P').setNumberFormat('0.0000');
  parameter.getRange('Q2:Q').setNumberFormat('yyyy-mm-dd hh:mm:ss');

  summary.getRange('H2:K').setNumberFormat('0.0000');

  calibration.getRange('C2:D').setNumberFormat('0%');
  calibration.getRange('F2:H').setNumberFormat('0.0%');
  calibration.getRange('I2:I').setNumberFormat('yyyy-mm-dd hh:mm:ss');
}


function btEnsureHeaders_(sheet, headers) {
  if (!sheet) throw new Error('必要なシートがありません。');

  if (sheet.getMaxColumns() < headers.length) {
    sheet.insertColumnsAfter(
      sheet.getMaxColumns(),
      headers.length - sheet.getMaxColumns()
    );
  }

  sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
}


function btClearDataRows_(sheet) {
  if (!sheet) return;

  const lastRow = sheet.getLastRow();
  const lastColumn = sheet.getLastColumn();

  if (lastRow > 1 && lastColumn > 0) {
    sheet
      .getRange(2, 1, lastRow - 1, lastColumn)
      .clearContent();
  }
}


function btFindLastDataRow_(sheet, idColumn) {
  const lastRow = sheet.getLastRow();
  if (lastRow <= 1) return 1;

  const values = sheet
    .getRange(2, idColumn, lastRow - 1, 1)
    .getDisplayValues();

  for (let i = values.length - 1; i >= 0; i--) {
    if (String(values[i][0] || '').trim() !== '') {
      return i + 2;
    }
  }

  return 1;
}


function btHeaderMap_(headers) {
  const map = {};

  headers.forEach(function(header, i) {
    map[String(header)] = i;
  });

  return map;
}


function btDeleteEngineTriggers_() {
  ScriptApp.getProjectTriggers().forEach(function(trigger) {
    if (
      trigger.getHandlerFunction() ===
      BT_ENGINE.TRIGGER_HANDLER
    ) {
      ScriptApp.deleteTrigger(trigger);
    }
  });
}


function btAsBoolean_(value) {
  return value === true ||
    String(value).toUpperCase() === 'TRUE' ||
    String(value) === '1';
}


function btDateText_(value) {
  if (value instanceof Date && !isNaN(value.getTime())) {
    return Utilities.formatDate(
      value,
      BT_CONFIG.TIMEZONE,
      'yyyy-MM-dd'
    );
  }

  const text = String(value || '').trim();
  const match = text.match(/^(\d{4})-(\d{2})-(\d{2})/);

  return match
    ? match[1] + '-' + match[2] + '-' + match[3]
    : text;
}


function btArgMax_(array) {
  let bestIndex = 0;
  let bestValue = -Infinity;

  array.forEach(function(value, i) {
    if (value > bestValue) {
      bestValue = value;
      bestIndex = i;
    }
  });

  return bestIndex;
}


function btMaxKey_(object) {
  let bestKey = '';
  let bestValue = -Infinity;

  Object.keys(object).forEach(function(key) {
    if (object[key] > bestValue) {
      bestValue = object[key];
      bestKey = key;
    }
  });

  return bestKey;
}


function btFiniteOr_(value, fallback) {
  const number = Number(value);
  return Number.isFinite(number) ? number : fallback;
}


function btClamp_(value, min, max) {
  return Math.min(Math.max(value, min), max);
}

  
　　　　
