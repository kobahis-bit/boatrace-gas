  const ss = SpreadsheetApp.openById(HM_CONFIG.SPREADSHEET_ID);

  const raceSheet = hmRequireSheet_(ss, HM_CONFIG.RACE_SHEET);
  const racerSheet = hmRequireSheet_(ss, HM_CONFIG.RACER_SHEET);
  const summarySheet = hmRequireSheet_(ss, HM_CONFIG.SUMMARY_SHEET);

  hmVerifySummaryHeaders_(summarySheet);

  const races = hmReadEvaluationRaces_(raceSheet);
  const racersByRace = hmReadRacersByRace_(racerSheet);

  hmValidateRaceData_(races, racersByRace);

  const result = {
    status: 'READY',
    spreadsheet: ss.getName(),
    evalPeriod:
      HM_CONFIG.EVAL_START +
      '〜' +
      HM_CONFIG.EVAL_END,
