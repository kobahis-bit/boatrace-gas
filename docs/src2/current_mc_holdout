function runHMMCHoldoutEvaluation() {
  const lock = LockService.getScriptLock();
  lock.waitLock(30000);

  try {
    const ss = SpreadsheetApp.openById(HM_CONFIG.SPREADSHEET_ID);

    const raceSheet = hmRequireSheet_(ss, HM_CONFIG.RACE_SHEET);
    const racerSheet = hmRequireSheet_(ss, HM_CONFIG.RACER_SHEET);
    const summarySheet = hmRequireSheet_(ss, HM_CONFIG.SUMMARY_SHEET);

    hmVerifySummaryHeaders_(summarySheet);

    const races = hmReadEvaluationRaces_(raceSheet);
    const racersByRace = hmReadRacersByRace_(racerSheet);

    hmValidateRaceData_(races, racersByRace);

    const metrics = hmEvaluateCurrentModel_(races, racersByRace);

    const testId = [
      'HOLDOUT',
      '20260708_20260714',
      'N24',
      'V0p25',
      'independent',
      HM_CONFIG.MODEL_VERSION
    ].join('_');

    const existingIds = hmReadExistingTestIds_(summarySheet);

    let appended = false;

    if (!existingIds.has(testId)) {
      const appendRow = hmFindAppendRow_(summarySheet);

      const output = [[
        '',
        testId,
        'Holdout / Noise=24 / Venue=0.25 / Corr=none',
        HM_CONFIG.NOISE_SD,
        HM_CONFIG.VENUE_WEIGHT,
        HM_CONFIG.CORRELATION_MODE,
        metrics.raceCount,
        metrics.top1Accuracy,
        metrics.brierScore,
        metrics.logLoss,
        metrics.boat1Brier,
        true,
        '評価期間=' +
          HM_CONFIG.EVAL_START +
          '〜' +
          HM_CONFIG.EVAL_END +
          '。採用中Morning MCを5000試行で準アウトオブサンプル評価。展示未使用。'
      ]];

      summarySheet
        .getRange(
          appendRow,
          1,
          1,
          HM_SUMMARY_HEADERS.length
        )
        .setValues(output);

      summarySheet
        .getRange(appendRow, 4, 1, 2)
        .setNumberFormat('0.000');

      summarySheet
        .getRange(appendRow, 7, 1, 1)
        .setNumberFormat('0');

      summarySheet
        .getRange(appendRow, 8, 1, 4)
        .setNumberFormat('0.0000');

      SpreadsheetApp.flush();
      appended = true;
    } else {
      console.log('既存Test_IDのため追記スキップ: ' + testId);
    }

    const result = {
      status: 'COMPLETED',
      testId: testId,
      modelVersion: HM_CONFIG.MODEL_VERSION,
      evalPeriod:
        HM_CONFIG.EVAL_START +
        '〜' +
        HM_CONFIG.EVAL_END,
      mcTrials: HM_CONFIG.MC_TRIALS,
      noiseSd: HM_CONFIG.NOISE_SD,
      venueWeight: HM_CONFIG.VENUE_WEIGHT,
      correlationMode: HM_CONFIG.CORRELATION_MODE,
      appended: appended,
      metrics: metrics
    };

    console.log(JSON.stringify(result, null, 2));
    return result;
  } finally {
    lock.releaseLock();
  }
}

