function normalizeTodayRaces_(payload) {
  const programs =
    payload && Array.isArray(payload.programs)
      ? payload.programs
      : [];

  const races = [];

  programs.forEach(function(program) {
    if (!program || !Array.isArray(program.boats)) return;
    if (program.boats.length !== 6) return;

    const venueCode = String(program.stadium_number).padStart(2, '0');
    const venue = VENUE_ADJUST[venueCode];

    if (!venue) {
      console.log('Venue_master未登録の場コード: ' + venueCode);
      return;
    }

    const raceNo = toInt_(program.number);
    if (!raceNo) return;

    const boats = program.boats
      .map(function(boat) {
        return normalizeBoat_(boat);
      })
      .sort(function(a, b) {
        return a.lane - b.lane;
      });

    if (
      boats.length !== 6 ||
      boats.some(function(boat) {
        return !boat.lane;
      })
    ) {
      console.log(venue.name + raceNo + 'R: 艇データを正規化できません');
      return;
    }

    races.push({
      venueCode: venueCode,
      venueName: venue.name,
      raceNo: raceNo,
      deadline: normalizeDeadline_(program.closed_at),
      raceDate: normalizeDate_(program.date),
      raceDateText: normalizeDateText_(program.date),
      boats: boats,
      dayLabel: program.day_label || '',
      gradeLabel: program.grade_label || '',
      gradeNumber: toInt_(program.grade_number),
      title: program.title || '',
      subtitle: program.subtitle || '',
      distance: toInt_(program.distance)
    });
  });

  return races.sort(function(a, b) {
    if (a.venueCode !== b.venueCode) {
      return a.venueCode.localeCompare(b.venueCode);
    }
    return a.raceNo - b.raceNo;
  });
}

