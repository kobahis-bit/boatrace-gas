function buildNoiseTransform_(correlationMode) {
  if (correlationMode === 'none') {
    return identityMatrix_(6);
  }

  if (correlationMode === 'fixed_cholesky_v1') {
    validateCorrelationMatrix_();
    return choleskyDecomposition_(CORR_MATRIX);
  }

  throw new Error('未対応のCORRELATION_MODEです: ' + correlationMode);
}

function identityMatrix_(size) {
  return Array.from({length: size}, function(_, row) {
    return Array.from({length: size}, function(__, column) {
      return row === column ? 1 : 0;
    });
  });
}

/**
 * 固定相関行列の安全確認。
 * 6×6、有限数、係数範囲、対角1、対称性、正定値、
 * 正本ハッシュ一致を確認し、異常時は処理を停止する。
 */
function validateCorrelationMatrix_() {
  const matrix = CORR_MATRIX;
  const size = 6;
  const tolerance = 1e-12;

  if (!Array.isArray(matrix) || matrix.length !== size) {
    throw new Error(
      '相関行列が6行ではありません。実際=' +
      (Array.isArray(matrix) ? matrix.length : '配列ではない')
    );
  }

  matrix.forEach(function(row, rowIndex) {
    if (!Array.isArray(row) || row.length !== size) {
      throw new Error(
        '相関行列の' +
        (rowIndex + 1) +
        '行目が6列ではありません。'
      );
    }

    row.forEach(function(value, columnIndex) {
      if (typeof value !== 'number' || !Number.isFinite(value)) {
        throw new Error(
          '相関行列に有限数以外があります。行=' +
          (rowIndex + 1) +
          ' 列=' +
          (columnIndex + 1)
        );
      }

      if (value < -1 || value > 1) {
        throw new Error(
          '相関係数が-1〜1の範囲外です。行=' +
          (rowIndex + 1) +
          ' 列=' +
          (columnIndex + 1) +
          ' 値=' +
          value
        );
      }
    });
  });

  for (let i = 0; i < size; i++) {
    if (Math.abs(matrix[i][i] - 1) > tolerance) {
      throw new Error(
        '相関行列の対角成分が1ではありません。index=' +
        (i + 1) +
        ' 値=' +
        matrix[i][i]
      );
    }

    for (let j = i + 1; j < size; j++) {
      if (Math.abs(matrix[i][j] - matrix[j][i]) > tolerance) {
        throw new Error(
          '相関行列が対称ではありません。行=' +
          (i + 1) +
          ' 列=' +
          (j + 1) +
          ' 値A=' +
          matrix[i][j] +
          ' 値B=' +
          matrix[j][i]
        );
      }
    }
  }

  // 正定値であることを確認する。
  choleskyDecomposition_(matrix);

  const actualHash = calculateCorrelationMatrixHash_(matrix);

  if (actualHash !== CORRELATION_MATRIX_HASH) {
    throw new Error(
      '相関行列のハッシュが正本と一致しません。expected=' +
      CORRELATION_MATRIX_HASH +
      ' actual=' +
      actualHash
    );
  }

  return {
    status: 'VALID',
    version: CORRELATION_VERSION,
    hash: actualHash,
    size: '6x6'
  };
}

/**
 * 行列を小数点以下3桁の固定形式へ正規化し、SHA-256を計算する。
 */
function calculateCorrelationMatrixHash_(matrix) {
  const canonicalText = matrix
    .map(function(row) {
      return row
        .map(function(value) {
          return Number(value).toFixed(3);
        })
        .join(',');
    })
    .join('\n');

  const digest = Utilities.computeDigest(
    Utilities.DigestAlgorithm.SHA_256,
    canonicalText,
    Utilities.Charset.UTF_8
  );

  return digest
    .map(function(byte) {
      const value = byte < 0 ? byte + 256 : byte;
      return ('0' + value.toString(16)).slice(-2);
    })
    .join('');
}

