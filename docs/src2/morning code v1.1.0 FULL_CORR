function loadLogicSettings_(ss) {
  const sheet = ss.getSheetByName(CONFIG.LOGIC_SETTINGS_SHEET);

  if (!sheet) {
    throw new Error('Logic_Settingsシートがありません: ' + CONFIG.LOGIC_SETTINGS_SHEET);
  }

  const values = sheet.getDataRange().getValues();

  if (values.length < 2) {
    throw new Error('Logic_Settingsに設定行がありません。');
  }

  const headers = values[0].map(function(value) {
    return String(value || '').trim();
  });

  const requiredHeaders = [
    'Key','Value','Type','Min','Max','Enabled','Description','Updated_At'
  ];

  const headerIndex = {};

  requiredHeaders.forEach(function(header) {
    const index = headers.indexOf(header);
    if (index === -1) {
      throw new Error('Logic_Settingsに必須列がありません: ' + header);
    }
    headerIndex[header] = index;
  });

  const settings = {};
  const seenKeys = new Set();
  const duplicateKeys = [];

  for (let rowIndex = 1; rowIndex < values.length; rowIndex++) {
    const row = values[rowIndex];
    const sheetRow = rowIndex + 1;
    const key = String(row[headerIndex.Key] || '').trim();

    if (!key) continue;

    if (seenKeys.has(key)) {
      duplicateKeys.push(key + '（' + sheetRow + '行目）');
      continue;
    }

    seenKeys.add(key);

    const enabled = parseBoolean_(
      row[headerIndex.Enabled],
      'Enabled',
      key,
      sheetRow
    );

    if (!enabled) continue;

    const type = String(row[headerIndex.Type] || '').trim().toLowerCase();

    if (SUPPORTED_SETTING_TYPES.indexOf(type) === -1) {
      throw new Error(
        'Logic_Settings ' +
        sheetRow +
        '行目: 未対応Typeです。Key=' +
        key +
        ' / Type=' +
        type
      );
    }

    const convertedValue = convertSettingValue_(
      row[headerIndex.Value],
      type,
      key,
      sheetRow
    );

    const minValue = parseBoundaryValue_(
      row[headerIndex.Min],
      type,
      key,
      sheetRow,
      'Min'
    );

    const maxValue = parseBoundaryValue_(
      row[headerIndex.Max],
      type,
      key,
      sheetRow,
      'Max'
    );

    validateSettingRange_(
      convertedValue,
      minValue,
      maxValue,
      type,
      key,
      sheetRow
    );

    settings[key] = convertedValue;
  }

  if (duplicateKeys.length) {
    throw new Error('Logic_Settingsに重複Keyがあります: ' + duplicateKeys.join(', '));
  }

  REQUIRED_LOGIC_KEYS.forEach(function(key) {
    if (!Object.prototype.hasOwnProperty.call(settings, key)) {
      throw new Error('Logic_Settingsに有効な必須Keyがありません: ' + key);
    }
  });

  // NO_VENUE_CODESはLogic_Settings上ではtextだが、実行中は正規化済み配列として扱う。
  settings.NO_VENUE_CODES = normalizeVenueCodeList_(settings.NO_VENUE_CODES);

  console.log('Logic_Settings読込結果:\n' + JSON.stringify(settings, null, 2));
  return Object.freeze(settings);
}

function convertSettingValue_(rawValue, type, key, sheetRow) {
  switch (type) {
    case 'text': {
      const value = String(
        rawValue === null || rawValue === undefined ? '' : rawValue
      ).trim();

      if (!value) {
        throw new Error(
          'Logic_Settings ' + sheetRow + '行目: text値が空です。Key=' + key
        );
      }

      return value;
    }

    case 'integer': {
      const number = parseStrictNumber_(rawValue, key, sheetRow, 'Value');

      if (!Number.isInteger(number)) {
        throw new Error(
          'Logic_Settings ' +
          sheetRow +
          '行目: integerではありません。Key=' +
          key +
          ' / Value=' +
          rawValue
        );
      }

      return number;
    }

    case 'number':
      return parseStrictNumber_(rawValue, key, sheetRow, 'Value');

    case 'percent':
      return parsePercent_(rawValue, key, sheetRow, 'Value');

    case 'boolean':
      return parseBoolean_(rawValue, 'Value', key, sheetRow);

    default:
      throw new Error('未対応Typeです。Key=' + key + ' / Type=' + type);
  }
}

function parseBoundaryValue_(rawValue, type, key, sheetRow, label) {
  if (rawValue === '' || rawValue === null || rawValue === undefined) {
    return null;
  }

  if (type === 'integer' || type === 'number') {
    return parseStrictNumber_(rawValue, key, sheetRow, label);
  }

  if (type === 'percent') {
    return parsePercent_(rawValue, key, sheetRow, label);
  }

  return null;
}

function validateSettingRange_(value, minValue, maxValue, type, key, sheetRow) {
  if (type !== 'integer' && type !== 'number' && type !== 'percent') {
    return;
  }

  if (minValue !== null && maxValue !== null && minValue > maxValue) {
    throw new Error(
      'Logic_Settings ' +
      sheetRow +
      '行目: MinがMaxを超えています。Key=' +
      key +
      ' / Min=' +
      minValue +
      ' / Max=' +
      maxValue
    );
  }

  if (minValue !== null && value < minValue) {
    throw new Error(
      'Logic_Settings ' +
      sheetRow +
      '行目: ValueがMin未満です。Key=' +
      key +
      ' / Value=' +
      value +
      ' / Min=' +
      minValue
    );
  }

  if (maxValue !== null && value > maxValue) {
    throw new Error(
      'Logic_Settings ' +
      sheetRow +
      '行目: ValueがMax超過です。Key=' +
      key +
      ' / Value=' +
      value +
      ' / Max=' +
      maxValue
    );
  }
}

function parseStrictNumber_(rawValue, key, sheetRow, label) {
  if (rawValue === '' || rawValue === null || rawValue === undefined) {
    throw new Error(
      'Logic_Settings ' +
      sheetRow +
      '行目: ' +
      label +
      'が空です。Key=' +
      key
    );
  }

  const normalized = String(rawValue).replace(/,/g, '').trim();
  const number = Number(normalized);

  if (!Number.isFinite(number)) {
    throw new Error(
      'Logic_Settings ' +
      sheetRow +
      '行目: 数値へ変換できません。Key=' +
      key +
      ' / ' +
      label +
      '=' +
      rawValue
    );
  }

  return number;
}

function parsePercent_(rawValue, key, sheetRow, label) {
  if (rawValue === '' || rawValue === null || rawValue === undefined) {
    throw new Error(
      'Logic_Settings ' +
      sheetRow +
      '行目: ' +
      label +
      'が空です。Key=' +
      key
    );
  }

  if (typeof rawValue === 'number') {
    if (!Number.isFinite(rawValue)) {
      throw new Error(
        'Logic_Settings ' + sheetRow + '行目: percent値が不正です。Key=' + key
      );
    }
    return rawValue > 1 ? rawValue / 100 : rawValue;
  }

  const text = String(rawValue).trim();
  const hasPercentMark = text.indexOf('%') !== -1;
  const number = Number(text.replace('%', '').replace(/,/g, '').trim());

  if (!Number.isFinite(number)) {
    throw new Error(
      'Logic_Settings ' +
      sheetRow +
      '行目: percentへ変換できません。Key=' +
      key +
      ' / ' +
      label +
      '=' +
      rawValue
    );
  }

  return hasPercentMark || number > 1 ? number / 100 : number;
}

function parseBoolean_(rawValue, label, key, sheetRow) {
  if (typeof rawValue === 'boolean') return rawValue;
  if (rawValue === 1) return true;
  if (rawValue === 0) return false;

  const normalized = String(rawValue || '').trim().toLowerCase();

  if (
    normalized === 'true' ||
    normalized === 'yes' ||
    normalized === 'y' ||
    normalized === '1'
  ) {
    return true;
  }

  if (
    normalized === 'false' ||
    normalized === 'no' ||
    normalized === 'n' ||
    normalized === '0'
  ) {
    return false;
  }

  throw new Error(
    'Logic_Settings ' +
    sheetRow +
    '行目: booleanへ変換できません。Key=' +
    key +
    ' / ' +
    label +
    '=' +
    rawValue
  );
}

function validateMorningModelSettings_(settings) {
  if (settings.MC_TRIALS < 1000) {
    throw new Error('MC_TRIALSは1000以上にしてください。現在=' + settings.MC_TRIALS);
  }

  if (settings.NOISE_SD <= 0) {
    throw new Error('NOISE_SDは0より大きくしてください。現在=' + settings.NOISE_SD);
  }

  if (settings.VENUE_WEIGHT < 0 || settings.VENUE_WEIGHT > 1) {
    throw new Error('VENUE_WEIGHTは0〜1の範囲にしてください。現在=' + settings.VENUE_WEIGHT);
  }

  if (SUPPORTED_CORRELATION_MODES.indexOf(settings.CORRELATION_MODE) === -1) {
    throw new Error('未対応のCORRELATION_MODEです: ' + settings.CORRELATION_MODE);
  }

  if (SUPPORTED_VENUE_MODELS.indexOf(settings.VENUE_MODEL) === -1) {
    throw new Error('未対応のVENUE_MODELです: ' + settings.VENUE_MODEL);
  }

  if (!Array.isArray(settings.NO_VENUE_CODES)) {
    throw new Error('NO_VENUE_CODESの内部変換に失敗しました。');
  }

  settings.NO_VENUE_CODES.forEach(function(code) {
    if (!Object.prototype.hasOwnProperty.call(VENUE_ADJUST, code)) {
      throw new Error('NO_VENUE_CODESに未登録の場コードがあります: ' + code);
    }
  });

  if (
    settings.VENUE_MODEL === 'D_HYBRID_V1' &&
    settings.NO_VENUE_CODES.length === 0
  ) {
    throw new Error('D_HYBRID_V1ではNO_VENUE_CODESを1件以上設定してください。');
  }

  if (
    settings.VENUE_MODEL === 'CURRENT_V1' &&
    settings.NO_VENUE_CODES.length > 0
  ) {
    throw new Error(
      'CURRENT_V1ではNO_VENUE_CODESを空にしてください。現在=' +
      settings.NO_VENUE_CODES.join(',')
    );
  }

  if (settings.ENABLE_EXHIBITION !== false) {
    throw new Error(
      '朝モデルではENABLE_EXHIBITIONをFALSEにしてください。' +
      '展示補正は未検証のため本番処理を停止しました。'
    );
  }
}

function normalizeVenueCodeList_(rawValue) {
  const text = Array.isArray(rawValue)
    ? rawValue.join(',')
    : String(rawValue === null || rawValue === undefined ? '' : rawValue);

  const codes = text
    .split(',')
    .map(function(value) {
      return String(value || '').trim();
    })
    .filter(function(value) {
      return value !== '';
    })
    .map(function(value) {
      if (!/^\d{1,2}$/.test(value)) {
        throw new Error('NO_VENUE_CODESの形式が不正です: ' + value);
      }
      return String(parseInt(value, 10)).padStart(2, '0');
    });

  const unique = [];
  const seen = new Set();

  codes.forEach(function(code) {
    if (seen.has(code)) {
      throw new Error('NO_VENUE_CODESに重複があります: ' + code);
    }
    seen.add(code);
    unique.push(code);
  });

  return Object.freeze(unique);
}

function getVenueAdjustValues_(venueCode, settings) {
  const code = String(venueCode || '').padStart(2, '0');
  const venue = VENUE_ADJUST[code];

  if (!venue) {
    throw new Error('会場補正表に未登録の場コードです: ' + code);
  }

  if (
    settings.VENUE_MODEL === 'D_HYBRID_V1' &&
    settings.NO_VENUE_CODES.indexOf(code) !== -1
  ) {
    return [0, 0, 0, 0, 0, 0];
  }

  return venue.values.slice();
}

