function validateBoatIdentities_(boats) {
  const errors = [];

  if (!Array.isArray(boats) || boats.length !== 6) {
    return ['6艇分のデータがありません'];
  }

  boats.forEach(function(boat, index) {
    const expectedLane = index + 1;

    if (boat.lane !== expectedLane) {
      errors.push(expectedLane + '号艇の艇番不一致=' + boat.lane);
    }

    if (!String(boat.racerName || '').trim()) {
      errors.push(expectedLane + '号艇の選手名欠損');
    }

    if (!/^\d{4}$/.test(String(boat.racerNumber || ''))) {
      errors.push(
        expectedLane +
        '号艇の登録番号不正=' +
        String(boat.racerNumber || '空欄')
      );
    }
  });

  return errors;
}

function calculateBaseScore_(boat, course, venueCode, settings) {
  const classPoint = CLASS_POINTS[boat.className] || 3;

  const nationalWin =
    isFiniteNumber_(boat.nationalWinRate) ? boat.nationalWinRate : 4.5;

  const localWin =
    isFiniteNumber_(boat.localWinRate) ? boat.localWinRate : nationalWin;

  const twoRate =
    isFiniteNumber_(boat.national2Rate) ? boat.national2Rate : 0.30;

  const threeRate =
    isFiniteNumber_(boat.national3Rate) ? boat.national3Rate : 0.48;

  const local2Rate =
    isFiniteNumber_(boat.local2Rate) ? boat.local2Rate : twoRate;

  const local3Rate =
    isFiniteNumber_(boat.local3Rate) ? boat.local3Rate : threeRate;

  const avgSt =
    isFiniteNumber_(boat.avgSt) && boat.avgSt > 0 ? boat.avgSt : 0.18;

  const motor =
    isFiniteNumber_(boat.motor2Rate) ? boat.motor2Rate : 0.33;

  const motor3 =
    isFiniteNumber_(boat.motor3Rate) ? boat.motor3Rate : 0.50;

  const boatRate =
    isFiniteNumber_(boat.boat2Rate) ? boat.boat2Rate : 0.33;

  const boat3 =
    isFiniteNumber_(boat.boat3Rate) ? boat.boat3Rate : 0.50;

  const flyingCount =
    isFiniteNumber_(boat.flyingCount) ? boat.flyingCount : 0;

  let score = 0;

  score += 30;
  score += classPoint * 2.2;
  score += nationalWin * 4.0;
  score += localWin * 1.8;
  score += twoRate * 16.0;
  score += threeRate * 6.0;
  score += local2Rate * 5.0;
  score += local3Rate * 2.0;
  score += clamp_((0.20 - avgSt) * 110, -5, 9);
  score += (motor - 0.33) * 20.0;
  score += (motor3 - 0.50) * 5.0;
  score += (boatRate - 0.33) * 7.0;
  score += (boat3 - 0.50) * 2.0;
  score -= flyingCount * 2.5;

  const courseBase = [20, 6, 2, 0, -5, -10][course - 1];
  score += courseBase;

  const venueValues = getVenueAdjustValues_(venueCode, settings);
  score += venueValues[course - 1] * settings.VENUE_WEIGHT;

  return score;
}

function runMonteCarlo_(baseScores, noiseTransform, trials, noiseSd) {
  const finishCounts = Array.from({length: 6}, function() {
    return [0, 0, 0];
  });

  const exacta = {};
  const quinella = {};
  const trio = {};

  for (let t = 0; t < trials; t++) {
    const z = Array.from({length: 6}, randn_);
    const corr = multiplyLowerTriangular_(noiseTransform, z);

    const ranking = baseScores
      .map(function(base, i) {
        return {
          lane: i + 1,
          value: base + corr[i] * noiseSd
        };
      })
      .sort(function(a, b) {
        return b.value - a.value;
      });

    for (let p = 0; p < 3; p++) {
      finishCounts[ranking[p].lane - 1][p]++;
    }

    const first = ranking[0].lane;
    const second = ranking[1].lane;
    const third = ranking[2].lane;

    increment_(exacta, first + '→' + second);

    increment_(
      quinella,
      [first, second].sort(function(a, b) {
        return a - b;
      }).join('=')
    );

    increment_(
      trio,
      [first, second, third].sort(function(a, b) {
        return a - b;
      }).join('=')
    );
  }

  return {
    finishCounts: finishCounts,
    exacta: exacta,
    quinella: quinella,
    trio: trio,
    trials: trials
  };
}

function summarizeResult_(result) {
  const trials = result.trials;

  const p1 = result.finishCounts.map(function(x) {
    return x[0] / trials;
  });

  const p2 = result.finishCounts.map(function(x) {
    return x[1] / trials;
  });

  const p3 = result.finishCounts.map(function(x) {
    return x[2] / trials;
  });

  const bestExacta = maxEntry_(result.exacta, trials);
  const bestQuinella = maxEntry_(result.quinella, trials);
  const bestTrio = maxEntry_(result.trio, trials);

  const inWin = p1[0];
  const inLose = 1 - inWin;

  const sorted = p1.slice().sort(function(a, b) {
    return b - a;
  });

  const entropy =
    -p1.reduce(function(sum, p) {
      return p > 0 ? sum + p * Math.log(p) : sum;
    }, 0) / Math.log(6);

  const gap = sorted[0] - sorted[1];

  const confidence = clamp_(
    (1 - entropy) * 0.55 +
    gap * 0.90 +
    sorted[0] * 0.25,
    0,
    1
  );

  let type = '中立';

  if (inWin >= 0.58 && gap >= 0.12) {
    type = 'ガチ';
  } else if (inWin <= 0.43 && Math.max.apply(null, p1.slice(1)) >= 0.20) {
    type = '穴';
  }

  const selected =
    (type === 'ガチ' && inWin >= 0.62) ||
    (type === '穴' && inWin <= 0.40 && confidence >= 0.30);

  return {
    p1: p1,
    p2: p2,
    p3: p3,
    bestExacta: bestExacta,
    bestQuinella: bestQuinella,
    bestTrio: bestTrio,
    inWin: inWin,
    inLose: inLose,
    confidence: confidence,
    screeningType: type,
    selected: selected
  };
}

