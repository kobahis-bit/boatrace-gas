function runMorningMonteCarlo() {
  const lock = LockService.getScriptLock();
  lock.waitLock(30000);

  try {
    validateStaticConfig_();
  validateCorrelationMatrix_();

    const ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);
    const settings = loadLogicSettings_(ss);
    validateMorningModelSettings_(settings);

    const payload = fetchJson_(CONFIG.API_URL);
    const races = normalizeTodayRaces_(payload);

    if (!races.length) {
      throw new Error(
        'APIからレースを抽出できませんでした。' +
        'debugTodayApiStructure を実行してログを確認してください。'
      );
    }

    validateApiRaceDate_(races);

    const sheet = ss.getSheetByName(CONFIG.OUTPUT_SHEET);
    if (!sheet) {
      throw new Error('出力シートがありません: ' + CONFIG.OUTPUT_SHEET);
    }

    verifyHeaders_(sheet);

    if (CONFIG.AUTO_FORMAT_OUTPUT_SHEET) {
      setupOutputSheetFormat_(sheet);
    }

    const existing = readExistingIds_(sheet);
    const noiseTransform = buildNoiseTransform_(settings.CORRELATION_MODE);
    const now = new Date();
    const rows = [];
    const errors = [];

    races.forEach(function(race) {
      try {
        if (!race.boats || race.boats.length !== 6) {
          errors.push(race.venueName + race.raceNo + 'R: 艇データが6艇ではありません');
          return;
        }

        const identityErrors = validateBoatIdentities_(race.boats);
        if (identityErrors.length) {
          errors.push(
            race.venueName +
            race.raceNo +
            'R: 選手情報異常 - ' +
            identityErrors.join(', ')
          );
          return;
        }

        const probabilityId = buildProbabilityId_(race, settings);

        if (existing.has(probabilityId) && !CONFIG.OVERWRITE_SAME_ID) {
          return;
        }

        const baseScores = race.boats.map(function(boat, idx) {
          return calculateBaseScore_(boat, idx + 1, race.venueCode, settings);
        });

        const result = runMonteCarlo_(
          baseScores,
          noiseTransform,
          settings.MC_TRIALS,
          settings.NOISE_SD
        );

        const summary = summarizeResult_(result);

        rows.push(
          buildOutputRow_(
            race,
            probabilityId,
            now,
            summary,
            baseScores,
            settings
          )
        );
      } catch (err) {
        errors.push(
          (race.venueName || '?') +
          (race.raceNo || '?') +
          'R: ' +
          err.message
        );
      }
    });

    if (rows.length) {
      const startRow = findLastProbabilityDataRow_(sheet) + 1;
      const writeRange = sheet.getRange(
        startRow,
        1,
        rows.length,
        OUTPUT_HEADERS.length
      );

      writeRange.setValues(rows);
      SpreadsheetApp.flush();

      const writtenIds = sheet
        .getRange(startRow, 1, rows.length, 1)
        .getDisplayValues()
        .filter(function(row) {
          return String(row[0] || '').trim() !== '';
        })
        .length;

      if (writtenIds !== rows.length) {
        throw new Error(
          '書き込み確認に失敗しました。予定=' +
          rows.length +
          '件 / 確認=' +
          writtenIds +
          '件'
        );
      }

      const lastColumnLetter = columnNumberToLetter_(OUTPUT_HEADERS.length);

      console.log(
        '書き込み範囲: ' +
        CONFIG.OUTPUT_SHEET +
        '!A' +
        startRow +
        ':' +
        lastColumnLetter +
        (startRow + rows.length - 1)
      );
    }

    const resultSummary = {
      status: 'COMPLETED',
      modelVersion: settings.MODEL_VERSION,
      mcTrials: settings.MC_TRIALS,
      noiseSd: settings.NOISE_SD,
      venueWeight: settings.VENUE_WEIGHT,
      venueModel: settings.VENUE_MODEL,
      noVenueCodes: settings.NO_VENUE_CODES,
      correlationMode: settings.CORRELATION_MODE,
      enableExhibition: settings.ENABLE_EXHIBITION,
      totalRaces: races.length,
      inserted: rows.length,
      skipped: races.length - rows.length,
      errors: errors
    };

    console.log(JSON.stringify(resultSummary, null, 2));
    return resultSummary;
  } finally {
    lock.releaseLock();
  }
}

