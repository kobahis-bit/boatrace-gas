function choleskyDecomposition_(matrix) {
  const size = matrix.length;

  const lower = Array.from({length: size}, function() {
    return Array(size).fill(0);
  });

  for (let i = 0; i < size; i++) {
    for (let j = 0; j <= i; j++) {
      let sum = 0;

      for (let k = 0; k < j; k++) {
        sum += lower[i][k] * lower[j][k];
      }

      if (i === j) {
        const value = matrix[i][i] - sum;

        if (value <= 1e-12) {
          throw new Error(
            '相関行列が正定値ではありません。index=' +
            i +
            ', value=' +
            value
          );
        }

        lower[i][j] = Math.sqrt(value);
      } else {
        lower[i][j] = (matrix[i][j] - sum) / lower[j][j];
      }
    }
  }

  return lower;
}

function multiplyLowerTriangular_(lower, vector) {
  return lower.map(function(row, i) {
    let sum = 0;

    for (let j = 0; j <= i; j++) {
      sum += row[j] * vector[j];
    }

    return sum;
  });
}

function randn_() {
  let u = 0;
  let v = 0;

  while (u === 0) u = Math.random();
  while (v === 0) v = Math.random();

  return (
    Math.sqrt(-2.0 * Math.log(u)) *
    Math.cos(2.0 * Math.PI * v)
  );
}

function maxEntry_(object, denominator) {
  let bestKey = '';
  let bestValue = -1;

  Object.keys(object).forEach(function(key) {
    if (object[key] > bestValue) {
      bestValue = object[key];
      bestKey = key;
    }
  });

  return {
    key: bestKey,
    prob: bestValue < 0 ? 0 : bestValue / denominator
  };
}

function increment_(object, key) {
  object[key] = (object[key] || 0) + 1;
}

function firstDefined_(object, keys) {
  for (let i = 0; i < keys.length; i++) {
    if (
      object &&
      Object.prototype.hasOwnProperty.call(object, keys[i]) &&
      object[keys[i]] !== null &&
      object[keys[i]] !== ''
    ) {
      return object[keys[i]];
    }
  }

  return null;
}

function normalizeVenueCode_(raw, name) {
  if (raw !== null && raw !== undefined && raw !== '') {
    const digits = String(raw).replace(/\D/g, '');

    if (digits) {
      const code = ('0' + parseInt(digits, 10)).slice(-2);

      if (VENUE_ADJUST[code]) {
        return code;
      }
    }
  }

  return VENUE_NAME_TO_CODE[String(name || '').trim()] || '';
}

function normalizeRate_(value) {
  const number = toNumber_(value);

  if (!isFiniteNumber_(number)) return NaN;

  return number > 1.5 ? number / 100 : number;
}

function normalizeRacerNumber_(value) {
  if (value === null || value === undefined || value === '') {
    return '';
  }

  return String(value).replace(/\D/g, '').trim();
}

function toNumber_(value) {
  if (value === null || value === undefined || value === '') {
    return NaN;
  }

  const number = Number(
    String(value)
      .replace('%', '')
      .replace(',', '.')
      .trim()
  );

  return Number.isFinite(number) ? number : NaN;
}

function toInt_(value) {
  const number = parseInt(value, 10);
  return Number.isFinite(number) ? number : 0;
}

function isFiniteNumber_(value) {
  return typeof value === 'number' && Number.isFinite(value);
}

function clamp_(value, min, max) {
  return Math.max(min, Math.min(max, value));
}

function normalizeDate_(value) {
  if (value instanceof Date && !isNaN(value.getTime())) {
    return value;
  }

  const text = String(value || '').trim();

  const match = text.match(
    /(\d{4})[-\/]?(\d{1,2})[-\/]?(\d{1,2})/
  );

  if (match) {
    return new Date(
      Number(match[1]),
      Number(match[2]) - 1,
      Number(match[3])
    );
  }

  const now = new Date();

  return new Date(
    now.getFullYear(),
    now.getMonth(),
    now.getDate()
  );
}

function normalizeDateText_(value) {
  const date = normalizeDate_(value);

  return Utilities.formatDate(
    date,
    CONFIG.TIMEZONE,
    'yyyy-MM-dd'
  );
}

function normalizeDeadline_(value) {
  if (value === null || value === undefined || value === '') {
    return '';
  }

  if (value instanceof Date && !isNaN(value.getTime())) {
    return Utilities.formatDate(
      value,
      CONFIG.TIMEZONE,
      'HH:mm'
    );
  }

  const text = String(value).trim();
  const match = text.match(/(\d{1,2}):(\d{2})/);

  return match
    ? ('0' + match[1]).slice(-2) + ':' + match[2]
    : text;
}

function columnNumberToLetter_(columnNumber) {
  let number = columnNumber;
  let result = '';

  while (number > 0) {
    const remainder = (number - 1) % 26;
    result = String.fromCharCode(65 + remainder) + result;
    number = Math.floor((number - 1) / 26);
  }

  return result;
}

function clearProbabilityLogData() {
  validateStaticConfig_();

  const ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);
  const sheet = ss.getSheetByName(CONFIG.OUTPUT_SHEET);

  if (!sheet) {
    throw new Error('出力シートがありません: ' + CONFIG.OUTPUT_SHEET);
  }

  const lastRow = sheet.getLastRow();

  if (lastRow >= 2) {
    sheet
      .getRange(
        2,
        1,
        lastRow - 1,
        OUTPUT_HEADERS.length
      )
      .clearContent();
  }

  SpreadsheetApp.flush();

  console.log(
    'GAS_Probability_Logのデータ行を消去しました。' +
    'ヘッダーと書式は残しています。'
  );
}

function describeStructure_(node, depth, maxDepth) {
  if (depth > maxDepth) return '…';
  if (node === null) return null;

  if (Array.isArray(node)) {
    return {
      type: 'array',
      length: node.length,
      sample:
        node.length
          ? describeStructure_(node[0], depth + 1, maxDepth)
          : null
    };
  }

  if (typeof node !== 'object') return typeof node;

  const output = {};

  Object.keys(node)
    .slice(0, 30)
    .forEach(function(key) {
      output[key] = describeStructure_(
        node[key],
        depth + 1,
        maxDepth
      );
    });

  return output;
}
