function btmCholesky_(matrix) {
  const size =
    matrix.length;

  const lower =
    Array.from(
      {
        length: size
      },
      function() {
        return Array(
          size
        ).fill(0);
      }
    );

  for (
    let i = 0;
    i < size;
    i++
  ) {
    for (
      let j = 0;
      j <= i;
      j++
    ) {
      let sum = 0;

      for (
        let k = 0;
        k < j;
        k++
      ) {
        sum +=
          lower[i][k] *
          lower[j][k];
      }

      if (i === j) {
        const value =
          matrix[i][i] -
          sum;

        if (
          value <= 0
        ) {
          throw new Error(
            '相関行列が正定値ではありません。'
          );
        }

        lower[i][j] =
          Math.sqrt(
            value
          );

      } else {
        lower[i][j] =
          (
            matrix[i][j] -
            sum
          ) /
          lower[j][j];
      }
    }
  }

  return lower;
}

function btmMultiplyLower_(
  lower,
  vector
) {
  return lower.map(
    function(row, i) {
      let sum = 0;

      for (
        let j = 0;
        j <= i;
        j++
      ) {
        sum +=
          row[j] *
          vector[j];
      }

      return sum;
    }
  );
}

/**
 * 再実行しても同じレースで同じ乱数列になる。
 */
function btmSeededRandom_(seed) {
  let state =
    seed >>> 0;

  return function() {
    state +=
      0x6D2B79F5;

    let t = state;

    t = Math.imul(
      t ^ (
        t >>> 15
      ),
      t | 1
    );

    t ^=
      t +
      Math.imul(
        t ^ (
          t >>> 7
        ),
        t | 61
      );

    return (
      (
        t ^ (
          t >>> 14
        )
      ) >>> 0
    ) / 4294967296;
  };
}

function btmHashString_(text) {
  let hash =
    2166136261;

  for (
    let i = 0;
    i < text.length;
    i++
  ) {
    hash ^=
      text.charCodeAt(i);

    hash =
      Math.imul(
        hash,
        16777619
      );
  }

  return hash >>> 0;
}

function btmRandnWithRandom_(random) {
  let u = 0;
  let v = 0;

  while (u === 0) {
    u = random();
  }

  while (v === 0) {
    v = random();
  }

  return (
    Math.sqrt(
      -2 *
      Math.log(u)
    ) *
    Math.cos(
      2 *
      Math.PI *
      v
    )
  );
}

function btmHeaderMap_(
  headers,
  required,
  sheetName
) {
  const map = {};

  headers.forEach(
    function(value, index) {
      map[
        String(
          value || ''
        ).trim()
      ] = index;
    }
  );

  required.forEach(
    function(name) {
      if (
        !Object.prototype
          .hasOwnProperty
          .call(
            map,
            name
          )
      ) {
        throw new Error(
          sheetName +
          'に必須列がありません: ' +
          name
        );
      }
    }
  );

  return map;
}

function btmRequireSheet_(
  ss,
  name
) {
  const sheet =
    ss.getSheetByName(name);

  if (!sheet) {
    throw new Error(
      'シートがありません: ' +
      name
    );
  }

  return sheet;
}

function btmDateText_(value) {
  if (
    value instanceof Date &&
    !isNaN(
      value.getTime()
    )
  ) {
    return Utilities.formatDate(
      value,
      BTM_CONFIG.TIMEZONE,
      'yyyy-MM-dd'
    );
  }

  const match =
    String(
      value || ''
    )
      .trim()
      .match(
        /(\d{4})[-\/](\d{1,2})[-\/](\d{1,2})/
      );

  if (!match) {
    return '';
  }

  return [
    match[1],
    (
      '0' +
      match[2]
    ).slice(-2),
    (
      '0' +
      match[3]
    ).slice(-2)
  ].join('-');
}

function btmClassName_(value) {
  const map = {
    1: 'A1',
    2: 'A2',
    3: 'B1',
    4: 'B2'
  };

  return map[
    parseInt(
      value,
      10
    )
  ] || 'B2';
}

function btmBoolean_(value) {
  if (
    typeof value ===
    'boolean'
  ) {
    return value;
  }

  const text =
    String(
      value || ''
    )
      .trim()
      .toLowerCase();

  return (
    text === 'true' ||
    text === '1' ||
    text === 'yes'
  );
}

function btmNumberOrNull_(value) {
  if (
    value === null ||
    value === undefined ||
    value === ''
  ) {
    return null;
  }

  const number =
    Number(
      String(value)
        .replace(
          /,/g,
          ''
        )
        .replace(
          '%',
          ''
        )
        .trim()
    );

  return Number.isFinite(
    number
  )
    ? number
    : null;
}

function btmRateOrNull_(value) {
  const number =
    btmNumberOrNull_(value);

  if (
    number === null
  ) {
    return null;
  }

  return number > 1.5
    ? number / 100
    : number;
}

function btmIntOrNull_(value) {
  if (
    value === null ||
    value === undefined ||
    value === ''
  ) {
    return null;
  }

  const number =
    parseInt(
      value,
      10
    );

  return Number.isFinite(
    number
  )
    ? number
    : null;
}

function btmPad2_(value) {
  const number =
    parseInt(
      value,
      10
    );

  return Number.isFinite(
    number
  )
    ? String(number)
        .padStart(
          2,
          '0'
        )
    : '';
}

function btmFinite_(value) {
  return (
    typeof value ===
      'number' &&
    Number.isFinite(
      value
    )
  );
}

function btmClamp_(
  value,
  min,
  max
) {
  return Math.max(
    min,
    Math.min(
      max,
      value
    )
  );
}

