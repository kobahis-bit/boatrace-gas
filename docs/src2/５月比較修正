/**
 * 比較を最初から開始する。
 */
function btmStartJuneModelComparison() {
  const lock = LockService.getScriptLock();
  lock.waitLock(30000);

  try {
    btmDeleteTriggers_();

    const dataset =
      btmLoadValidationDataset_();

    const candidate =
      btmLoadCandidateAdjust_();

    btmValidateCandidate_(candidate);

    const props =
      PropertiesService.getScriptProperties();

    props.setProperties({
      [BTM_CONFIG.PROP_STATUS]:
        BTM_CONFIG.STATUS_RUNNING,

      [BTM_CONFIG.PROP_INDEX]:
        '0',

      [BTM_CONFIG.PROP_TOTAL]:
        String(dataset.length),

      [BTM_CONFIG.PROP_MESSAGE]:
        '6月未見データ比較を開始',

      [BTM_CONFIG.PROP_STARTED_AT]:
        new Date().toISOString(),

      [BTM_CONFIG.PROP_A]:
        JSON.stringify(
          btmNewAggregate_()
        ),

      [BTM_CONFIG.PROP_B]:
        JSON.stringify(
          btmNewAggregate_()
        ),

      [BTM_CONFIG.PROP_C]:
        JSON.stringify(
          btmNewAggregate_()
        ),

      [BTM_CONFIG.PROP_VENUE_A]:
        JSON.stringify({}),

      [BTM_CONFIG.PROP_VENUE_B]:
        JSON.stringify({}),

      [BTM_CONFIG.PROP_VENUE_C]:
        JSON.stringify({})
    }, true);

    const result = {
      status:
        BTM_CONFIG.STATUS_RUNNING,

      totalValidRaces:
        dataset.length,

      mcTrials:
        BTM_CONFIG.MC_TRIALS,

      racesPerBatch:
        BTM_CONFIG.RACES_PER_BATCH,

      models:
        BTM_MODEL_NAMES,

      candidateRunId:
        BTM_CONFIG.CANDIDATE_RUN_ID,

      note:
        'Cは5月候補値を全144セル使用。6月結果による選別なし。'
    };

    console.log(
      JSON.stringify(result, null, 2)
    );

    return btmRunJuneModelComparisonBatch();

  } finally {
    lock.releaseLock();
  }
}

/**
 * 1バッチ分を処理し、
 * 未完了なら次回トリガーを作る。
 */
function btmRunJuneModelComparisonBatch() {
  const lock =
    LockService.getScriptLock();

  lock.waitLock(30000);

  try {
    const props =
      PropertiesService.getScriptProperties();

    const status =
      props.getProperty(
        BTM_CONFIG.PROP_STATUS
      );

    if (
      status !==
      BTM_CONFIG.STATUS_RUNNING
    ) {
      btmDeleteTriggers_();

      return btmCheckJuneModelComparisonStatus();
    }

    const dataset =
      btmLoadValidationDataset_();

    const candidate =
      btmLoadCandidateAdjust_();

    const transform =
      btmCholesky_(
        BTM_CORR_MATRIX
      );

    let index = Number(
      props.getProperty(
        BTM_CONFIG.PROP_INDEX
      ) || 0
    );

    const endIndex = Math.min(
      index +
        BTM_CONFIG.RACES_PER_BATCH,
      dataset.length
    );

    const aggA =
      btmReadAggregate_(
        BTM_CONFIG.PROP_A
      );

    const aggB =
      btmReadAggregate_(
        BTM_CONFIG.PROP_B
      );

    const aggC =
      btmReadAggregate_(
        BTM_CONFIG.PROP_C
      );

    const venueAggA =
      btmReadVenueAggregate_(
        BTM_CONFIG.PROP_VENUE_A
      );

    const venueAggB =
      btmReadVenueAggregate_(
        BTM_CONFIG.PROP_VENUE_B
      );

    const venueAggC =
      btmReadVenueAggregate_(
        BTM_CONFIG.PROP_VENUE_C
      );

    for (
      ;
      index < endIndex;
      index++
    ) {
      const race = dataset[index];

      const baseWithoutVenue =
        race.boats.map(
          function(boat, i) {
            return btmCalculateBaseScore_(
              boat,
              i + 1
            );
          }
        );

      const currentValues =
        BTM_CURRENT_ADJUST[
          race.venueCode
        ] || [0, 0, 0, 0, 0, 0];

      const candidateValues =
        candidate[
          race.venueCode
        ] || [0, 0, 0, 0, 0, 0];

      const scoreSets = [
        baseWithoutVenue.slice(),

        baseWithoutVenue.map(
          function(score, i) {
            return (
              score +
              currentValues[i] *
                BTM_CONFIG.VENUE_WEIGHT
            );
          }
        ),

        baseWithoutVenue.map(
          function(score, i) {
            return (
              score +
              candidateValues[i] *
                BTM_CONFIG.VENUE_WEIGHT
            );
          }
        )
      ];

      const probabilitySets =
        btmRunSharedMonteCarlo_(
          scoreSets,
          transform,
          BTM_CONFIG.MC_TRIALS,
          BTM_CONFIG.NOISE_SD,
          race.raceId
        );

      btmUpdateAggregate_(
        aggA,
        probabilitySets[0],
        race.firstLane
      );

      btmUpdateAggregate_(
        aggB,
        probabilitySets[1],
        race.firstLane
      );

      btmUpdateAggregate_(
        aggC,
        probabilitySets[2],
        race.firstLane
      );

      btmUpdateVenueAggregate_(
        venueAggA,
        race.venueCode,
        race.venue,
        probabilitySets[0],
        race.firstLane
      );

      btmUpdateVenueAggregate_(
        venueAggB,
        race.venueCode,
        race.venue,
        probabilitySets[1],
        race.firstLane
      );

      btmUpdateVenueAggregate_(
        venueAggC,
        race.venueCode,
        race.venue,
        probabilitySets[2],
        race.firstLane
      );
    }

    props.setProperties({
      [BTM_CONFIG.PROP_INDEX]:
        String(index),

      [BTM_CONFIG.PROP_TOTAL]:
        String(dataset.length),

      [BTM_CONFIG.PROP_MESSAGE]:
        '処理済み=' +
        index +
        '/' +
        dataset.length,

      [BTM_CONFIG.PROP_A]:
        JSON.stringify(aggA),

      [BTM_CONFIG.PROP_B]:
        JSON.stringify(aggB),

      [BTM_CONFIG.PROP_C]:
        JSON.stringify(aggC),

      [BTM_CONFIG.PROP_VENUE_A]:
        JSON.stringify(venueAggA),

      [BTM_CONFIG.PROP_VENUE_B]:
        JSON.stringify(venueAggB),

      [BTM_CONFIG.PROP_VENUE_C]:
        JSON.stringify(venueAggC)
    }, false);

    if (index >= dataset.length) {
      const report =
        btmFinalizeComparison_(
          aggA,
          aggB,
          aggC,
          venueAggA,
          venueAggB,
          venueAggC
        );

      props.setProperty(
        BTM_CONFIG.PROP_STATUS,
        BTM_CONFIG.STATUS_COMPLETED
      );

      props.setProperty(
        BTM_CONFIG.PROP_MESSAGE,
        '比較完了'
      );

      btmDeleteTriggers_();

      console.log(
        JSON.stringify(report, null, 2)
      );

      return report;
    }

    btmScheduleNextTrigger_();

    const result = {
      status:
        BTM_CONFIG.STATUS_RUNNING,

      processed:
        index,

      total:
        dataset.length,

      progress:
        dataset.length > 0
          ? index / dataset.length
          : 0,

      nextBatchFrom:
        index
    };

    console.log(
      JSON.stringify(result, null, 2)
    );

    return result;

  } catch (err) {
    const props =
      PropertiesService.getScriptProperties();

    props.setProperty(
      BTM_CONFIG.PROP_STATUS,
      BTM_CONFIG.STATUS_FAILED
    );

    props.setProperty(
      BTM_CONFIG.PROP_MESSAGE,
      err.message
    );

    btmDeleteTriggers_();

    throw err;

  } finally {
    lock.releaseLock();
  }
}

function btmStopJuneModelComparison() {
  const props =
    PropertiesService.getScriptProperties();

  props.setProperty(
    BTM_CONFIG.PROP_STATUS,
    BTM_CONFIG.STATUS_STOPPED
  );

  props.setProperty(
    BTM_CONFIG.PROP_MESSAGE,
    'ユーザー操作で停止'
  );

  btmDeleteTriggers_();

  return btmCheckJuneModelComparisonStatus();
}

function btmResumeJuneModelComparison() {
  const props =
    PropertiesService.getScriptProperties();

  const index =
    props.getProperty(
      BTM_CONFIG.PROP_INDEX
    );

  const total =
    props.getProperty(
      BTM_CONFIG.PROP_TOTAL
    );

  if (
    index === null ||
    total === null
  ) {
    throw new Error(
      '再開可能な進捗情報がありません。'
    );
  }

  props.setProperty(
    BTM_CONFIG.PROP_STATUS,
    BTM_CONFIG.STATUS_RUNNING
  );

  props.setProperty(
    BTM_CONFIG.PROP_MESSAGE,
    '比較を再開'
  );

  return btmRunJuneModelComparisonBatch();
}

function btmCheckJuneModelComparisonStatus() {
  const props =
    PropertiesService.getScriptProperties();

  const index = Number(
    props.getProperty(
      BTM_CONFIG.PROP_INDEX
    ) || 0
  );

  const total = Number(
    props.getProperty(
      BTM_CONFIG.PROP_TOTAL
    ) || 0
  );

  const result = {
    status:
      props.getProperty(
        BTM_CONFIG.PROP_STATUS
      ) ||
      BTM_CONFIG.STATUS_IDLE,

    processed:
      index,

    total:
      total,

    progress:
      total > 0
        ? index / total
        : 0,

    message:
      props.getProperty(
        BTM_CONFIG.PROP_MESSAGE
      ) || '',

    startedAt:
      props.getProperty(
        BTM_CONFIG.PROP_STARTED_AT
      ) || ''
  };

  console.log(
    JSON.stringify(result, null, 2)
  );

  return result;
}

/**
 * 6月の有効レースを読み込む。
 * 1レース6艇、本番コース・着順・1着艇が揃うものだけ。
 */
function btmLoadValidationDataset_() {
  const ss =
    SpreadsheetApp.openById(
      BTM_CONFIG.SPREADSHEET_ID
    );

  const raceSheet =
    btmRequireSheet_(
      ss,
      BTM_CONFIG.RACE_SHEET
    );

  const racerSheet =
    btmRequireSheet_(
      ss,
      BTM_CONFIG.RACER_SHEET
    );

  const raceValues =
    raceSheet
      .getDataRange()
      .getValues();

  const racerValues =
    racerSheet
      .getDataRange()
      .getValues();

  const rh =
    btmHeaderMap_(
      raceValues[0],
      [
        'Race_ID',
        '日付',
        '場コード',
        '場',
        '1着艇',
        'Result有'
      ],
      BTM_CONFIG.RACE_SHEET
    );

  const bh =
    btmHeaderMap_(
      racerValues[0],
      [
        'Race_ID',
        '日付',
        '場コード',
        '場',
        '艇番',
        '級別番号',
        'F数',
        '平均ST',
        '全国勝率',
        '全国2連率',
        '全国3連率',
        '当地勝率',
        '当地2連率',
        '当地3連率',
        'モーター2連率',
        'モーター3連率',
        'ボート2連率',
        'ボート3連率',
        '結果有',
        '本番コース',
        '着順'
      ],
      BTM_CONFIG.RACER_SHEET
    );

  const raceMap = {};

  raceValues
    .slice(1)
    .forEach(function(row) {
      const raceId =
        String(
          row[rh.Race_ID] || ''
        ).trim();

      if (!raceId) {
        return;
      }

      const date =
        btmDateText_(
          row[rh['日付']]
        );

      if (
        date <
          BTM_CONFIG.VALIDATION_START ||
        date >
          BTM_CONFIG.VALIDATION_END
      ) {
        return;
      }

      const firstLane =
        btmIntOrNull_(
          row[rh['1着艇']]
        );

      if (
        !btmBoolean_(
          row[rh['Result有']]
        ) ||
        firstLane === null ||
        firstLane < 1 ||
        firstLane > 6
      ) {
        return;
      }

      raceMap[raceId] = {
        raceId:
          raceId,

        date:
          date,

        venueCode:
          btmPad2_(
            row[rh['場コード']]
          ),

        venue:
          String(
            row[rh['場']] || ''
          ).trim(),

        firstLane:
          firstLane,

        boats:
          []
      };
    });

  racerValues
    .slice(1)
    .forEach(function(row) {
      const raceId =
        String(
          row[bh.Race_ID] || ''
        ).trim();

      const race =
        raceMap[raceId];

      if (!race) {
        return;
      }

      const date =
        btmDateText_(
          row[bh['日付']]
        );

      if (
        date <
          BTM_CONFIG.VALIDATION_START ||
        date >
          BTM_CONFIG.VALIDATION_END
      ) {
        return;
      }

      if (
        !btmBoolean_(
          row[bh['結果有']]
        )
      ) {
        return;
      }

      const lane =
        btmIntOrNull_(
          row[bh['艇番']]
        );

      const resultCourse =
        btmIntOrNull_(
          row[bh['本番コース']]
        );

      const finish =
        btmIntOrNull_(
          row[bh['着順']]
        );

      if (
        lane === null ||
        resultCourse === null ||
        finish === null
      ) {
        return;
      }

      race.boats.push({
        lane:
          lane,

        resultCourse:
          resultCourse,

        finish:
          finish,

        className:
          btmClassName_(
            row[bh['級別番号']]
          ),

        flyingCount:
          btmNumberOrNull_(
            row[bh['F数']]
          ),

        avgSt:
          btmNumberOrNull_(
            row[bh['平均ST']]
          ),

        nationalWinRate:
          btmNumberOrNull_(
            row[bh['全国勝率']]
          ),

        national2Rate:
          btmRateOrNull_(
            row[bh['全国2連率']]
          ),

        national3Rate:
          btmRateOrNull_(
            row[bh['全国3連率']]
          ),

        localWinRate:
          btmNumberOrNull_(
            row[bh['当地勝率']]
          ),

        local2Rate:
          btmRateOrNull_(
            row[bh['当地2連率']]
          ),

        local3Rate:
          btmRateOrNull_(
            row[bh['当地3連率']]
          ),

        motor2Rate:
          btmRateOrNull_(
            row[bh['モーター2連率']]
          ),

        motor3Rate:
          btmRateOrNull_(
            row[bh['モーター3連率']]
          ),

        boat2Rate:
          btmRateOrNull_(
            row[bh['ボート2連率']]
          ),

        boat3Rate:
          btmRateOrNull_(
            row[bh['ボート3連率']]
          )
      });
    });

  return Object.keys(raceMap)
    .map(function(key) {
      return raceMap[key];
    })
    .filter(function(race) {
      if (
        race.boats.length !== 6
      ) {
        return false;
      }

      race.boats.sort(
        function(a, b) {
          return a.lane - b.lane;
        }
      );

      const lanes =
        race.boats.map(
          function(x) {
            return x.lane;
          }
        );

      return [
        1, 2, 3, 4, 5, 6
      ].every(
        function(lane, i) {
          return lanes[i] === lane;
        }
      );
    })
    .sort(function(a, b) {
      return a.raceId.localeCompare(
        b.raceId
      );
    });
}

/**
 * 5月候補値をParameter_Testから読み込む。
 * 6月の方向再現性列・推奨列は一切参照しない。
 */
function btmLoadCandidateAdjust_() {
  const ss =
    SpreadsheetApp.openById(
      BTM_CONFIG.SPREADSHEET_ID
    );

  const sheet =
    btmRequireSheet_(
      ss,
      BTM_CONFIG.PARAMETER_SHEET
    );

  const values =
    sheet
      .getDataRange()
      .getValues();

  let headerRow = -1;
  let header = null;

  for (
    let i = 0;
    i < values.length;
    i++
  ) {
    if (
      String(
        values[i][0] || ''
      ).trim() === 'Run_ID' &&
      String(
        values[i][1] || ''
      ).trim() === 'Report_Type' &&
      values[i]
        .map(String)
        .indexOf(
          'V2候補スコア'
        ) !== -1
    ) {
      headerRow = i;

      header =
        btmHeaderMap_(
          values[i],
          [
            'Run_ID',
            'Report_Type',
            '場コード',
            'コース',
            'V2候補スコア'
          ],
          BTM_CONFIG.PARAMETER_SHEET
        );
    }
  }

  if (
    headerRow < 0 ||
    !header
  ) {
    throw new Error(
      'VENUE_ADJUST_CANDIDATEのヘッダーを検出できません。'
    );
  }

  const adjust = {};

  for (
    let i = headerRow + 1;
    i < values.length;
    i++
  ) {
    const row = values[i];

    if (
      String(
        row[header.Run_ID] || ''
      ).trim() !==
      BTM_CONFIG.CANDIDATE_RUN_ID
    ) {
      continue;
    }

    if (
      String(
        row[
          header.Report_Type
        ] || ''
      ).trim() !==
      'VENUE_ADJUST_CANDIDATE'
    ) {
      continue;
    }

    const code =
      btmPad2_(
        row[
          header['場コード']
        ]
      );

    const course =
      btmIntOrNull_(
        row[
          header['コース']
        ]
      );

    const score =
      btmNumberOrNull_(
        row[
          header['V2候補スコア']
        ]
      );

    if (
      !code ||
      course === null ||
      course < 1 ||
      course > 6 ||
      score === null
    ) {
      continue;
    }

    if (!adjust[code]) {
      adjust[code] =
        [0, 0, 0, 0, 0, 0];
    }

    adjust[code][
      course - 1
    ] = score;
  }

  return adjust;
}

function btmValidateCandidate_(
  candidate
) {
  const codes =
    Object.keys(candidate);

  if (codes.length !== 24) {
    throw new Error(
      '候補会場数が24ではありません。実際=' +
      codes.length
    );
  }

  codes.forEach(
    function(code) {
      if (
        !Array.isArray(
          candidate[code]
        ) ||
        candidate[code].length !== 6
      ) {
        throw new Error(
          '候補値が6コース分ありません: ' +
          code
        );
      }
    }
  );
}

/**
 * 現行朝モデルの会場補正以外のベーススコア。
 */
function btmCalculateBaseScore_(
  boat,
  course
) {
  const classPoint =
    BTM_CLASS_POINTS[
      boat.className
    ] || 3;

  const nationalWin =
    btmFinite_(
      boat.nationalWinRate
    )
      ? boat.nationalWinRate
      : 4.5;

  const localWin =
    btmFinite_(
      boat.localWinRate
    )
      ? boat.localWinRate
      : nationalWin;

  const twoRate =
    btmFinite_(
      boat.national2Rate
    )
      ? boat.national2Rate
      : 0.30;

  const threeRate =
    btmFinite_(
      boat.national3Rate
    )
      ? boat.national3Rate
      : 0.48;

  const local2Rate =
    btmFinite_(
      boat.local2Rate
    )
      ? boat.local2Rate
      : twoRate;

  const local3Rate =
    btmFinite_(
      boat.local3Rate
    )
      ? boat.local3Rate
      : threeRate;

  const avgSt =
    btmFinite_(
      boat.avgSt
    ) &&
    boat.avgSt > 0
      ? boat.avgSt
      : 0.18;

  const motor =
    btmFinite_(
      boat.motor2Rate
    )
      ? boat.motor2Rate
      : 0.33;

  const motor3 =
    btmFinite_(
      boat.motor3Rate
    )
      ? boat.motor3Rate
      : 0.50;

  const boatRate =
    btmFinite_(
      boat.boat2Rate
    )
      ? boat.boat2Rate
      : 0.33;

  const boat3 =
    btmFinite_(
      boat.boat3Rate
    )
      ? boat.boat3Rate
      : 0.50;

  const flyingCount =
    btmFinite_(
      boat.flyingCount
    )
      ? boat.flyingCount
      : 0;

  let score = 0;

  score += 30;
  score += classPoint * 2.2;
  score += nationalWin * 4.0;
  score += localWin * 1.8;
  score += twoRate * 16.0;
  score += threeRate * 6.0;
  score += local2Rate * 5.0;
  score += local3Rate * 2.0;

  score += btmClamp_(
    (0.20 - avgSt) * 110,
    -5,
    9
  );

  score +=
    (motor - 0.33) *
    20.0;

  score +=
    (motor3 - 0.50) *
    5.0;

  score +=
    (boatRate - 0.33) *
    7.0;

  score +=
    (boat3 - 0.50) *
    2.0;

  score -=
    flyingCount *
    2.5;

  score += [
    20,
    6,
    2,
    0,
    -5,
    -10
  ][course - 1];

  return score;
}

/**
 * 3モデルに共通乱数を使用したMonte Carlo。
 */
function btmRunSharedMonteCarlo_(
  scoreSets,
  transform,
  trials,
  noiseSd,
  seedText
) {
  const counts =
    scoreSets.map(
      function() {
        return [
          0, 0, 0, 0, 0, 0
        ];
      }
    );

  const random =
    btmSeededRandom_(
      btmHashString_(
        seedText
      )
    );

  for (
    let t = 0;
    t < trials;
    t++
  ) {
    const z = [];

    for (
      let i = 0;
      i < 6;
      i++
    ) {
      z.push(
        btmRandnWithRandom_(
          random
        )
      );
    }

    const corr =
      btmMultiplyLower_(
        transform,
        z
      );

    scoreSets.forEach(
      function(scores, m) {
        let bestLane = 0;
        let bestValue = -Infinity;

        for (
          let i = 0;
          i < 6;
          i++
        ) {
          const value =
            scores[i] +
            corr[i] *
              noiseSd;

          if (
            value > bestValue
          ) {
            bestValue = value;
            bestLane = i;
          }
        }

        counts[m][bestLane]++;
      }
    );
  }

  return counts.map(
    function(modelCounts) {
      return modelCounts.map(
        function(count) {
          return count / trials;
        }
      );
    }
  );
}

