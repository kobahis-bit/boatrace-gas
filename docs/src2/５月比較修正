    SpreadsheetApp.openById(
      BTM_CONFIG.SPREADSHEET_ID
    );

  const sheet =
    btmRequireSheet_(
      ss,
      BTM_CONFIG.PARAMETER_SHEET
    );

  const headers = [
    'Run_ID',
    'Report_Type',
    '場コード',
    '場',
    'モデル名',
    '対象レース数',
    'Top1_Accuracy',
    'Brier_Score',
    'Log_Loss',
    '1号艇_Brier',
    'Brier順位',
    'LogLoss順位',
    'Top1順位',
    '会場別推奨モデル',
    '判定メモ'
  ];

  const modelMaps = [
    {
      model:
        'A_NO_VENUE',

      data:
        venueAggA
    },
    {
      model:
        'B_CURRENT_V1',

      data:
        venueAggB
    },
    {
      model:
        'C_SHRUNK_V2',

      data:
        venueAggC
    }
  ];

  const venueCodes =
    Object.keys(
      Object.assign(
        {},
        venueAggA,
        venueAggB,
        venueAggC
      )
    ).sort();

  const rows = [];

  const winCounts = {
    A_NO_VENUE: 0,
    B_CURRENT_V1: 0,
    C_SHRUNK_V2: 0
  };

  const brierWinCounts = {
    A_NO_VENUE: 0,
    B_CURRENT_V1: 0,
    C_SHRUNK_V2: 0
  };

  const logLossWinCounts = {
    A_NO_VENUE: 0,
    B_CURRENT_V1: 0,
    C_SHRUNK_V2: 0
  };

  venueCodes.forEach(
    function(code) {
      const metrics =
        modelMaps
          .map(
            function(item) {
              const venueEntry =
                item.data[code];

              if (
                !venueEntry
              ) {
                return null;
              }

              const metric =
                btmMetricRow_(
                  item.model,
                  venueEntry.aggregate
                );

              metric.venue =
                venueEntry.venue ||
                '';

              metric.venueCode =
                code;

              return metric;
            }
          )
          .filter(Boolean);

      if (
        metrics.length === 0
      ) {
        return;
      }

      const brierOrder =
        metrics
          .slice()
          .sort(
            function(a, b) {
              return (
                a.brier -
                b.brier
              );
            }
          );

      const logOrder =
        metrics
          .slice()
          .sort(
            function(a, b) {
              return (
                a.logLoss -
                b.logLoss
              );
            }
          );

      const top1Order =
        metrics
          .slice()
          .sort(
            function(a, b) {
              return (
                b.top1 -
                a.top1
              );
            }
          );

      brierWinCounts[
        brierOrder[0].model
      ]++;

      logLossWinCounts[
        logOrder[0].model
      ]++;

      const recommended =
        btmChooseVenueModel_(
          brierOrder,
          logOrder,
          top1Order
        );

      winCounts[
        recommended.model
      ]++;

      metrics.forEach(
        function(metric) {
          rows.push([
            runId,
            'VENUE_MODEL_COMPARISON',
            metric.venueCode,
            metric.venue,
            metric.model,
            metric.n,
            metric.top1,
            metric.brier,
            metric.logLoss,
            metric.inBrier,

            brierOrder.findIndex(
              function(x) {
                return (
                  x.model ===
                  metric.model
                );
              }
            ) + 1,

            logOrder.findIndex(
              function(x) {
                return (
                  x.model ===
                  metric.model
                );
              }
            ) + 1,

            top1Order.findIndex(
              function(x) {
                return (
                  x.model ===
                  metric.model
                );
              }
            ) + 1,

            recommended.model,

            (
              metric.model ===
              recommended.model
                ? recommended.memo
                : ''
            )
          ]);
        }
      );
    }
