    sheet.insertRowsAfter(
      sheet.getMaxRows(),
      requiredLastRow -
        sheet.getMaxRows()
    );
  }

  sheet
    .getRange(
      startRow,
      1,
      1,
      headers.length
    )
    .setValues([
      headers
    ])
    .setFontWeight(
      'bold'
    )
    .setBackground(
      '#D9EAD3'
    );

  if (
    rows.length > 0
  ) {
    sheet
      .getRange(
        startRow + 1,
        1,
        rows.length,
        headers.length
      )
      .setValues(rows);

    sheet
      .getRange(
        startRow + 1,
        7,
        rows.length,
        1
      )
      .setNumberFormat(
        '0.00%'
      );

    sheet
      .getRange(
        startRow + 1,
        8,
        rows.length,
        3
      )
      .setNumberFormat(
        '0.0000'
      );
  }

  const summaryHeaders = [
    'Run_ID',
    'Report_Type',
    'モデル名',
    '会場別推奨数',
    'Brier首位会場数',
    'LogLoss首位会場数'
  ];

  const summaryRows =
    BTM_MODEL_NAMES.map(
      function(model) {
        return [
          runId,
          'VENUE_MODEL_SUMMARY',
          model,
          winCounts[model],
          brierWinCounts[model],
          logLossWinCounts[model]
        ];
      }
    );

  sheet
    .getRange(
      summaryStartRow,
      1,
      1,
      summaryHeaders.length
    )
    .setValues([
      summaryHeaders
    ])
    .setFontWeight(
      'bold'
    )
    .setBackground(
      '#CFE2F3'
    );

  sheet
    .getRange(
      summaryStartRow + 1,
      1,
      summaryRows.length,
      summaryHeaders.length
    )
    .setValues(
      summaryRows
    );

  SpreadsheetApp.flush();

  return {
    venueCount:
      venueCodes.length,

    recommendedCounts:
      winCounts,

    brierWinnerCounts:
      brierWinCounts,

    logLossWinnerCounts:
      logLossWinCounts
  };
}

function btmChooseVenueModel_(
  brierOrder,
  logOrder,
  top1Order
) {
  const brierBest =
    brierOrder[0];

  const logBest =
    logOrder[0];

  const top1Best =
    top1Order[0];

  if (
    brierBest.model ===
    logBest.model
  ) {
    return {
      model:
        brierBest.model,

      memo:
        'Brier・Log Lossとも首位'
    };
  }

  const brierSecond =
    brierOrder[1];

  const brierGap =
    brierSecond
      ? (
          brierSecond.brier -
          brierBest.brier
        )
      : 0;

  const logSecond =
    logOrder[1];

  const logGap =
    logSecond
      ? (
          logSecond.logLoss -
          logBest.logLoss
        )
      : 0;

  if (
    brierBest.model ===
      'B_CURRENT_V1' &&
    brierGap >= 0.002
  ) {
    return {
      model:
        'B_CURRENT_V1',

      memo:
        'Brier改善を優先'
    };
  }

  if (
    logBest.model ===
      'B_CURRENT_V1' &&
    logGap >= 0.01
  ) {
    return {
      model:
        'B_CURRENT_V1',

      memo:
        'Log Loss改善を優先'
    };
  }

  if (
    brierBest.model ===
    top1Best.model
  ) {
    return {
      model:
        brierBest.model,

      memo:
        'Brier・Top1首位'
    };
  }

  return {
    model:
      brierBest.model,

    memo:
      'Brier最優先で選択'
  };
}

