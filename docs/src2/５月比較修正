/**
 * 多クラスBrier:
 * 6艇それぞれの(p-y)^2を合計。
 *
 * Log Loss:
 * 実際の1着艇へ割り当てた確率の-ln(p)。
 *
 * 1号艇Brier:
 * 1号艇勝利を二値事象として計算。
 */
function btmUpdateAggregate_(
  agg,
  probabilities,
  actualLane
) {
  const actualIndex =
    actualLane - 1;

  let predictedIndex = 0;

  for (
    let i = 1;
    i < 6;
    i++
  ) {
    if (
      probabilities[i] >
      probabilities[
        predictedIndex
      ]
    ) {
      predictedIndex = i;
    }
  }

  if (
    predictedIndex ===
    actualIndex
  ) {
    agg.top1Correct++;
  }

  let brier = 0;

  for (
    let i = 0;
    i < 6;
    i++
  ) {
    const y =
      i === actualIndex
        ? 1
        : 0;

    const diff =
      probabilities[i] - y;

    brier +=
      diff * diff;
  }

  const actualProbability =
    Math.max(
      BTM_CONFIG.MIN_PROBABILITY,
      probabilities[
        actualIndex
      ]
    );

  const inProbability =
    probabilities[0];

  const inActual =
    actualLane === 1
      ? 1
      : 0;

  agg.n++;
  agg.brierSum += brier;

  agg.logLossSum +=
    -Math.log(
      actualProbability
    );

  agg.inBrierSum +=
    Math.pow(
      inProbability -
      inActual,
      2
    );

  const binIndex =
    Math.min(
      9,
      Math.floor(
        inProbability * 10
      )
    );

  agg.bins[
    binIndex
  ].n++;

  agg.bins[
    binIndex
  ].probSum +=
    inProbability;

  agg.bins[
    binIndex
  ].winSum +=
    inActual;
}

function btmUpdateVenueAggregate_(
  venueMap,
  venueCode,
  venueName,
  probabilities,
  actualLane
) {
  if (
    !venueMap[venueCode]
  ) {
    venueMap[venueCode] = {
      venueCode:
        venueCode,

      venue:
        venueName,

      aggregate:
        btmNewAggregate_()
    };
  }

  btmUpdateAggregate_(
    venueMap[
      venueCode
    ].aggregate,
    probabilities,
    actualLane
  );
}

function btmFinalizeComparison_(
  aggA,
  aggB,
  aggC,
  venueAggA,
  venueAggB,
  venueAggC
) {
  const rows = [
    btmMetricRow_(
      'A_NO_VENUE',
      aggA
    ),

    btmMetricRow_(
      'B_CURRENT_V1',
      aggB
    ),

    btmMetricRow_(
      'C_SHRUNK_V2',
      aggC
    )
  ];

  const runId =
    Utilities.formatDate(
      new Date(),
      BTM_CONFIG.TIMEZONE,
      'yyyyMMdd_HHmmss'
    );

  btmAppendComparisonReport_(
    runId,
    rows,
    [
      aggA,
      aggB,
      aggC
    ]
  );

  const venueSummary =
    btmAppendVenueComparisonReport_(
      runId,
      venueAggA,
      venueAggB,
      venueAggC
    );

  const bestBrier =
    rows
      .slice()
      .sort(
        function(a, b) {
          return (
            a.brier -
            b.brier
          );
        }
      )[0];

  const bestLogLoss =
    rows
      .slice()
      .sort(
        function(a, b) {
          return (
            a.logLoss -
            b.logLoss
          );
        }
      )[0];

  const bestTop1 =
    rows
      .slice()
      .sort(
        function(a, b) {
          return (
            b.top1 -
            a.top1
          );
        }
      )[0];

  return {
    status:
      BTM_CONFIG.STATUS_COMPLETED,

    runId:
      runId,

    races:
      rows[0].n,

    models:
      rows,

    bestBrier:
      bestBrier.model,

    bestLogLoss:
      bestLogLoss.model,

    bestTop1Accuracy:
      bestTop1.model,

    venueSummary:
      venueSummary,

    adoptionRule:
      'BrierとLog Lossを最優先。Top1悪化なし、1号艇Brier悪化なし、会場別の大幅悪化なしを確認して採否決定。'
  };
}

function btmMetricRow_(
  modelName,
  agg
) {
  return {
    model:
      modelName,

    n:
      agg.n,

    top1:
      agg.n > 0
        ? agg.top1Correct /
          agg.n
        : 0,

    brier:
      agg.n > 0
        ? agg.brierSum /
          agg.n
        : 0,

    logLoss:
      agg.n > 0
        ? agg.logLossSum /
          agg.n
        : 0,

    inBrier:
      agg.n > 0
        ? agg.inBrierSum /
          agg.n
        : 0
  };
}

